{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AutoFlow",
  "version": "0.1.0",
  "identifier": "com.autoflow.frontops",
  "build": {
    "frontendDist": "https://autoflow-mvp.vercel.app",
