NEXT_PUBLIC_APP_MODE=mock
# Site key for staff accounts, notices, invites (default: default)
NEXT_PUBLIC_SITE_ID=
# 단일 기본 채팅방 UUID (참가자 패널 조회용)
NEXT_PUBLIC_DEFAULT_CHAT_ROOM_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 중요: 채팅/유지보수/티켓 생성 요청에 들어가는 `user_id` / `created_by` 값.
# - 반드시 Supabase `users` 테이블의 `id` 컬럼(UUID)이어야 합니다. (예: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# - 미설정이면 DB uuid 제약으로 인해 아래 기능이 모두 막힙니다: 채팅 전송, 유지보수(티켓) 생성, 수동 티켓 연결/삭제, front-ops 카드 액션 전송
NEXT_PUBLIC_CHAT_SEND_USER_ID=
# Staff account login codes (4 digits, unique) — run: node scripts/seed-staff-accounts.mjs
# Never commit real codes to git.
STAFF_ACCOUNT_CLEANER1_CODE=
STAFF_ACCOUNT_CLEANER2_CODE=
STAFF_ACCOUNT_CLEANER3_CODE=
STAFF_ACCOUNT_CLEANER4_CODE=
STAFF_ACCOUNT_CLEANER5_CODE=
STAFF_ACCOUNT_CLEANER6_CODE=
NEXT_PUBLIC_STAFF_USER_CLEANER1_ID=
NEXT_PUBLIC_STAFF_USER_CLEANER2_ID=
NEXT_PUBLIC_STAFF_USER_CLEANER3_ID=
NEXT_PUBLIC_STAFF_USER_CLEANER4_ID=
NEXT_PUBLIC_STAFF_USER_CLEANER5_ID=
NEXT_PUBLIC_STAFF_USER_CLEANER6_ID=
# PC /chat ops panel: staff notice admin + list APIs (server validates STAFF_ADMIN_SECRET header)
STAFF_ADMIN_SECRET=
# Same value as STAFF_ADMIN_SECRET — required for browser /chat admin panel (MVP; do not commit)
NEXT_PUBLIC_STAFF_ADMIN_SECRET=
# Optional alias for manager if different from CHAT_SEND_USER_ID
NEXT_PUBLIC_STAFF_USER_MANAGER_ID=
# Core v0.1: AI/번역 후처리 기본 OFF. 1일 때만 send 후 비동기 실행.
CHAT_ENABLE_AI_POSTPROCESS=
# Front Ops: 카드 액션 전송에 우선 사용할 `users.id`(UUID). 미설정이면 `NEXT_PUBLIC_CHAT_SEND_USER_ID`를 사용합니다.
NEXT_PUBLIC_FRONT_OPS_SEND_USER_ID=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRIMARY_URL=
# Direct Postgres URI (scripts/migrations). May fail DNS on IPv6-only db.* hosts (Windows/Node).
DATABASE_URL=
# Optional: Supabase Dashboard → Transaction pooler connection string (fallback for migration scripts)
SUPABASE_DB_POOLER_URL=

# Minimal repro (separate Supabase project)
SUPABASE_MIN_URL=
SUPABASE_MIN_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
