NEXT_PUBLIC_APP_MODE=mock
# 단일 기본 채팅방 UUID (참가자 패널 조회용). migration seed UUID와 동일해야 함.
NEXT_PUBLIC_DEFAULT_CHAT_ROOM_ID=
# 서버 전용 기본 채팅방 UUID. migration seed(00000000-0000-0000-0000-000000000001)와 다르면 서버가 거부함.
DEFAULT_CHAT_ROOM_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 중요: 채팅/유지보수/티켓 생성 요청에 들어가는 `user_id` / `created_by` 값.
# - 반드시 Supabase `users` 테이블의 `id` 컬럼(UUID)이어야 합니다. (예: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# - 미설정이면 DB uuid 제약으로 인해 아래 기능이 모두 막힙니다: 채팅 전송, 유지보수(티켓) 생성, 수동 티켓 연결/삭제, front-ops 카드 액션 전송
NEXT_PUBLIC_CHAT_SEND_USER_ID=
# Staff chat user UUIDs (run: node scripts/seed-staff-users.mjs)
NEXT_PUBLIC_STAFF_USER_CLEANER1_ID=
NEXT_PUBLIC_STAFF_USER_CLEANER2_ID=
# Optional alias for manager if different from CHAT_SEND_USER_ID
NEXT_PUBLIC_STAFF_USER_MANAGER_ID=
# Core v0.1: AI/번역 후처리 기본 OFF. 1일 때만 send 후 비동기 실행.
CHAT_ENABLE_AI_POSTPROCESS=
# Front Ops: 카드 액션 전송에 우선 사용할 `users.id`(UUID). 미설정이면 `NEXT_PUBLIC_CHAT_SEND_USER_ID`를 사용합니다.
NEXT_PUBLIC_FRONT_OPS_SEND_USER_ID=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRIMARY_URL=

# Stay journal (univer-ops ledger) — Preview/Production values set in Vercel before deploy
STAY_JOURNAL_SUPABASE_URL=
STAY_JOURNAL_SERVICE_ROLE_KEY=

# Minimal repro (separate Supabase project)
SUPABASE_MIN_URL=
SUPABASE_MIN_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
